# Copy this file to `.env` and fill in your own API keys.
# `.env` is gitignored — never commit it.

# ─────────────────────────────────────────────────────────────────────
# DeepSeek API  (https://platform.deepseek.com)
# Used by: deepseek-chat  (DeepSeek-V3)
# ─────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─────────────────────────────────────────────────────────────────────
# SiliconFlow API  (https://siliconflow.cn)
# Used by: Qwen/Qwen2.5-7B-Instruct, Qwen/Qwen2.5-14B-Instruct,
#          Qwen/Qwen2.5-32B-Instruct
# ─────────────────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=your_siliconflow_key_here

# ─────────────────────────────────────────────────────────────────────
# (Optional) HuggingFace mirror — uncomment if huggingface.co is slow
# or blocked from your network.
# ─────────────────────────────────────────────────────────────────────
# HF_ENDPOINT=https://hf-mirror.com
